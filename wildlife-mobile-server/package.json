{
  "name": "wildlife-mobile-server",
  "version": "1.0.0",
  "description": "Backend API for Wildlife Warning and Deterrence System",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "npx dotenv-cli -e .env.test -- jest --runInBand --detectOpenHandles",
    "test:report": "npx dotenv-cli -e .env.test -- jest --runInBand --detectOpenHandles --json --outputFile=test-report.json",
    "test:check": "node scripts/check-testcases.js",
    "validate": "npm run lint && npm run build && npm run test && npm run test:report"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.11",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.17.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
